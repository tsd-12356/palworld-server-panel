# Copy this file to .env before using docker compose.
PANEL_PORT=8080
PALWORLD_PORT=8211
PALWORLD_QUERY_PORT=27015
RCON_PORT=25575

# Change these before exposing the server outside your private network.
RCON_PASSWORD=change-me-rcon-password
PANEL_SECRET_KEY=change-me-panel-secret-key

PALWORLD_CONTAINER_NAME=palworld-panel-palworld-1
PANEL_CONTAINER_NAME=palworld-panel
PALWORLD_APP_ID=2394010

SERVER_NAME=Palworld Docker Server
SERVER_DESCRIPTION=Managed by Palworld Panel
SERVER_MAX_PLAYERS=32

PANEL_ASSET_VERSION=docker

# MOD manager
MOD_LIBRARY_ROOT=/app/data/mod-library
MOD_UPLOAD_MAX_BYTES=1073741824
PALWORLD_MOD_MODE=pak-safe
