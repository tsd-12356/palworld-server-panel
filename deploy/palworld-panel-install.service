[Unit]
Description=Palworld Panel Installer
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/demo/palworld-panel
EnvironmentFile=/etc/palworld-panel.env
ExecStart=/usr/bin/python3 /home/demo/palworld-panel/panel_install.py --service
TimeoutStartSec=7200
